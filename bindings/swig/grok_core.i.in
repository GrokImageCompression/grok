%module grok_core

// Dynamically include grok.h using CMake's configured path
%{
#include "@GROK_CORE_INCLUDE_PATH@/grok.h"
%}

%include stdint.i


%typemap(out) grk_image_comp* {
    grk_image* img_ptr = (grk_image*) SWIG_Python_GetSwigThis(*swig_obj);
    int num_components = img_ptr->numcomps;
    PyObject* py_list = PyList_New(num_components);

    for (int i = 0; i < num_components; i++) {
        PyObject* py_comp = SWIG_NewPointerObj((void*)(&($1[i])), SWIGTYPE_p__grk_image_comp, 0);
        PyList_SetItem(py_list, i, py_comp);
    }
    $result = py_list;
}

%include "@GROK_CORE_INCLUDE_PATH@/grok.h"

%inline %{
/* Create an image where all components share the same dimensions and precision */
grk_image* grk_image_new_uniform(uint16_t numcmpts, uint32_t w, uint32_t h,
                                  uint8_t dx, uint8_t dy, uint8_t prec,
                                  bool sgnd, GRK_COLOR_SPACE clrspc) {
    grk_image_comp* comps = (grk_image_comp*)calloc(numcmpts, sizeof(grk_image_comp));
    if (!comps)
        return NULL;
    for (uint16_t i = 0; i < numcmpts; i++) {
        comps[i].w = w;
        comps[i].h = h;
        comps[i].dx = dx;
        comps[i].dy = dy;
        comps[i].prec = prec;
        comps[i].sgnd = sgnd;
    }
    grk_image* img = grk_image_new(numcmpts, comps, clrspc, true);
    free(comps);
    /* Zero-initialize all component data so unset pixels don't cause
       undefined behaviour during compression (T1/T2 bit-plane calculations). */
    if (img) {
        for (uint16_t i = 0; i < numcmpts; i++) {
            if (img->comps[i].data) {
                size_t pixels = (size_t)img->comps[i].stride * img->comps[i].h;
                memset(img->comps[i].data, 0, pixels * sizeof(int32_t));
            }
        }
    }
    return img;
}

/* Set a layer rate on grk_cparameters (workaround for C array item assignment) */
void grk_cparameters_set_layer_rate(grk_cparameters* p, uint16_t layer, double rate) {
    p->layer_rate[layer] = rate;
}

/* Set a layer distortion on grk_cparameters */
void grk_cparameters_set_layer_distortion(grk_cparameters* p, uint16_t layer, double distortion) {
    p->layer_distortion[layer] = distortion;
}
%}


%extend _grk_progression_state {
    // Get the maximum layer value in layers_per_resolution
    uint16_t get_max_layers() {
        uint16_t max_layer = 0;
        for (int i = 0; i < self->num_resolutions; i++) {
            if (self->layers_per_resolution[i] > max_layer) {
                max_layer = self->layers_per_resolution[i];
            }
        }
        return max_layer;
    }

    // Set all elements in layers_per_resolution to a specified value
    void set_max_layers(uint16_t value) {
        for (int i = 0; i < self->num_resolutions; i++) {
            self->layers_per_resolution[i] = value;
        }
    }
}

%extend grk_swath_buffer {
    /*
     * Bind a Python buffer-protocol object (bytearray, memoryview, etc.) as the
     * raw data pointer for this swath buffer.  The Python object must remain alive
     * until grk_decompress_wait_swath_copy() returns.
     *
     * Usage:
     *   buf = bytearray(total_bytes)
     *   swath_buf.set_data(buf)
     */
    void set_data(PyObject* py_buf) {
        Py_buffer view;
        if (PyObject_GetBuffer(py_buf, &view, PyBUF_WRITABLE) == -1)
            return;
        $self->data = view.buf;
        PyBuffer_Release(&view);
    }

    /*
     * Read the swath buffer contents back as a Python bytes object.
     * Call only after grk_decompress_wait_swath_copy() has returned.
     * size_bytes must equal the total buffer size in bytes.
     */
    PyObject* get_data_bytes(size_t size_bytes) {
        if (!$self->data)
            Py_RETURN_NONE;
        return PyBytes_FromStringAndSize((const char*)$self->data, (Py_ssize_t)size_bytes);
    }

    /*
     * Set the band_map from a Python list of ints (1-based component indices).
     * The list must have numcomps elements.  A copy is stored internally and
     * freed on the next call or when the object is destroyed.
     *
     * Usage:
     *   # Identity mapping for 3-band image
     *   swath_buf.set_band_map([1, 2, 3])
     */
    void set_band_map(PyObject* py_list) {
        if (!PyList_Check(py_list))
            return;
        Py_ssize_t n = PyList_Size(py_list);
        if (n <= 0)
            return;
        // Free any previous allocation
        free($self->band_map);
        $self->band_map = (int*)malloc(n * sizeof(int));
        if (!$self->band_map) return;
        for (Py_ssize_t i = 0; i < n; ++i) {
            PyObject* item = PyList_GetItem(py_list, i);
            $self->band_map[i] = (int)PyLong_AsLong(item);
        }
        $self->numcomps = (uint16_t)n;
    }

    /*
     * Configure BSQ (band-sequential) layout convenience helper.
     * Sets pixel_space, line_space, band_space for a packed BSQ buffer:
     *   pixel_space = elem_bytes
     *   line_space  = width * elem_bytes
     *   band_space  = height * width * elem_bytes
     *
     * Usage:
     *   swath_buf.set_bsq_layout(width, height)
     */
    void set_bsq_layout(uint32_t width, uint32_t height) {
        int elem_bytes = ($self->prec <= 8) ? 1 : ($self->prec <= 16) ? 2 : 4;
        $self->pixel_space = elem_bytes;
        $self->line_space  = (int64_t)width * elem_bytes;
        $self->band_space  = (int64_t)width * height * elem_bytes;
    }
}
